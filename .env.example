# --- モック切り替え -------------------------------------------------
# "true" にすると API キーがあってもモック実装を使う
USE_MOCK_GOOGLE=true
USE_MOCK_AI=true
USE_MOCK_BILLING=true

# --- Google Business Profile API ------------------------------------
# 未設定の場合は自動的にモッククライアントが使われる
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# --- AI返信生成 (Anthropic / OpenAI 等) ------------------------------
# 未設定の場合はモック返信生成が使われる
AI_API_KEY=

# --- Stripe ----------------------------------------------------------
# 未設定の場合はモック請求クライアントが使われる
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
